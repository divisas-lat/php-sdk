{
    "name": "divisas-lat/php-sdk",
    "description": "El SDK oficial de PHP para la API de Divisas.lat",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Rodmar Zavala",
            "email": "rodmar@example.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.8",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "illuminate/support": "^13.7",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "DivisasLat\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DivisasLat\\Laravel\\DivisasServiceProvider"
            ],
            "aliases": {
                "Divisas": "DivisasLat\\Laravel\\Facades\\Divisas"
            }
        }
    },
    "minimum-stability": "stable"
}
